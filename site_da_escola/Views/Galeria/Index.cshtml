@{
    Layout = "_Layout";
    ViewData["Title"] = "Galeria de Fotos";
}

<div class="container py-5">
    <h1 class="text-center mb-4">Galeria de Fotos</h1>

    <div class="row g-4">
        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
            <div class="card shadow-sm">
                <img src="~/assets/Imagem1.png" class="card-img-top galeria-img" alt="Foto 1">
                <div class="card-body text-center">
                    <p class="card-text">Sabrina Furriel, jovem senadora 2025.</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
            <div class="card shadow-sm">
                <img src="~/assets/Imagem2.png" class="card-img-top galeria-img" alt="Foto 2">
                <div class="card-body text-center">
                    <p class="card-text">Imagem da escola.</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
            <div class="card shadow-sm">
                <img src="~/assets/Imagem3.png" class="card-img-top galeria-img" alt="Foto 3">
                <div class="card-body text-center">
                    <p class="card-text">Imagem da escola.</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
            <div class="card shadow-sm">
                <img src="~/assets/Imagem4.png" class="card-img-top galeria-img" alt="Foto 4">
                <div class="card-body text-center">
                    <p class="card-text">Imagem da escola.</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
            <div class="card shadow-sm">
                <img src="~/assets/Imagem5.png" class="card-img-top galeria-img" alt="Foto 5">
                <div class="card-body text-center">
                    <p class="card-text">Imagem da escola.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .galeria-img {
        width: 100%;
        height: 250px; 
        object-fit: cover; 
        background-color: #f8f9fa; 
        border-radius: 0.5rem;
    }

    .card {
        border: none;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.1);
    }
</style>
