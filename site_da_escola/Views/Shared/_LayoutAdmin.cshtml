<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/Admin.css" asp-append-version="true" />

</head>

<body class="bg-light">
    <header class="header d-flex align-items-center justify-content-between px-4">
        <a asp-controller="AdminPage" asp-action="Index" class="navbar-brand">
            <i class="bi bi-mortarboard-fill me-2"></i> Painel Escolar
        </a>

        <nav class="d-flex align-items-center gap-3">
            <span class="fw-semibold">
                <i class="bi bi-person-circle me-1"></i> Admin
            </span>
            <a asp-controller="Home" asp-action="Index" class="nav-link">
                <i class="bi bi-box-arrow-right me-1"></i> Sair
            </a>
        </nav>
    </header>

    <div class="d-flex">
        <!-- 🔹 SIDEBAR -->
        <aside class="sidebar d-flex flex-column">
            <a asp-controller="AdminPage" asp-action="Index">
                <i class="bi bi-speedometer2 me-2"></i> Dashboard
            </a>
            <a asp-controller="AdminPage" asp-action="PostarNoticia">
                <i class="bi bi-newspaper me-2"></i> Postar Notícia
            </a>
            <a asp-controller="AdminPage" asp-action="PostarEventos">
                <i class="bi bi-calendar-event me-2"></i> Postar Evento
            </a>
            <a asp-controller="Home" asp-action="Index">
                <i class="bi bi-house-door me-2"></i> Voltar ao Site
            </a>
        </aside>

    </div>
        <!-- 🔹 CONTEÚDO -->
        <main class="container">
            @RenderBody()
        </main>

    <footer class="text-center py-3 text-muted border-top">
        &copy; 2025 - site_da_escola | Painel Administrativo
    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
